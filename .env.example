# =============================================================================
# TaxBot environment configuration
# Copy to `.env` and fill in real secrets.
# =============================================================================

# --- Postgres ---
# Direct Postgres DSN used by asyncpg for parent-child operations and migrations.
# Format: postgresql://USER:PASSWORD@HOST:PORT/DBNAME
TAXBOT_POSTGRES_DSN=postgresql://postgres:postgres@localhost:5432/postgres
# --- Unstructured Hosted API ---
# https://unstructured.io/api-key-hosted
TAXBOT_UNSTRUCTURED_API_KEY=replace-with-unstructured-api-key
TAXBOT_UNSTRUCTURED_API_URL=https://api.unstructuredapp.io

# --- Hugging Face Inference API (BAAI/bge-large-en-v1.5, 1024-d) ---
TAXBOT_HUGGINGFACE_API_TOKEN=replace-with-hf-api-token
TAXBOT_EMBEDDING_MODEL=BAAI/bge-large-en-v1.5
TAXBOT_EMBEDDING_DIMENSION=1024

# --- Table summarization LLM ---
# Primary: Google AI Studio Gemini Flash
TAXBOT_GEMINI_API_KEY=replace-with-google-ai-studio-key
TAXBOT_GEMINI_MODEL=gemini-2.0-flash
# Fallback: OpenRouter
TAXBOT_OPENROUTER_API_KEY=replace-with-openrouter-key
TAXBOT_OPENROUTER_MODEL=google/gemini-flash-1.5

# --- Generation LLM (answer synthesis stage) ---
TAXBOT_ANSWER_LLM_PROVIDER=gemini
TAXBOT_ANSWER_LLM_MODEL=gemini-2.0-flash

# --- Ingestion controls ---
# Inclusive lower bound for the historical backfill (last 5 tax years).
TAXBOT_BACKFILL_OLDEST_TAX_YEAR=2020
# Comma-separated allowlist of languages to keep. Use "*" to disable filtering.
TAXBOT_LANGUAGE_ALLOWLIST=en
# Layer 1 narrative hygiene: drop IRS print/proof metadata and trailing index
# sections before chunking. Set to false to index raw parsed narratives.
TAXBOT_NARRATIVE_CONTENT_FILTER_ENABLED=true
# Seconds between IRS AJAX page requests (anti-rate-limit throttle).
TAXBOT_IRS_REQUEST_THROTTLE_SECONDS=1.5
TAXBOT_IRS_REQUEST_TIMEOUT_SECONDS=30.0
TAXBOT_IRS_MAX_RETRIES=4
# Increase TAXBOT_GEMINI_RETRY_MAX_WAIT when hitting sustained quota limits.
TAXBOT_GEMINI_MAX_RETRIES=6
TAXBOT_GEMINI_RETRY_MAX_WAIT=60.0
# Parallelism caps during backfill. Reduce to 1-2 on free-tier API plans.
TAXBOT_HF_EMBED_CONCURRENCY=4
TAXBOT_TABLE_SUMMARY_CONCURRENCY=4

# --- API ---
# Comma-separated browser origins allowed to call the API (frontend dev server).
TAXBOT_CORS_ALLOW_ORIGINS=http://localhost:5173

# --- Qdrant Cloud vector store ---
# Cluster URL from the Qdrant Cloud console, e.g. https://xxx.us-east4.gcp.cloud.qdrant.io:6333
TAXBOT_QDRANT_URL=https://your-cluster.qdrant.io:6333
TAXBOT_QDRANT_API_KEY=replace-with-qdrant-api-key
# Collection name
TAXBOT_QDRANT_COLLECTION=taxbot_child_nodes
# fastembed BM25 model for sparse retrieval
TAXBOT_BM25_MODEL=Qdrant/bm25
# Top-K tuning (number of child candidates from Qdrant / max assembled parent contexts)
TAXBOT_RETRIEVAL_TOP_K_CHILDREN=24
TAXBOT_RETRIEVAL_TOP_K_PARENTS=6
# RRF constant k; higher values flatten rank differences between dense and sparse legs
TAXBOT_RETRIEVAL_RRF_K=60

# --- Security ---
# Random delimiter tokens used to fence user input. Should be regenerated per env.
TAXBOT_USER_QUERY_START_TAG=USER_QUERY_START_5f3c1e
TAXBOT_USER_QUERY_END_TAG=USER_QUERY_END_5f3c1e
# Layer 2 retrieval-confidence gate: block weak/off-topic retrievals.
TAXBOT_RETRIEVAL_CONFIDENCE_GATE_ENABLED=true
TAXBOT_RETRIEVAL_MIN_HYBRID_SCORE=0.35
# Optional ambiguity guard. Leave empty to disable.
TAXBOT_RETRIEVAL_MIN_SCORE_GAP=

# --- Evaluation gates ---
TAXBOT_FAITHFULNESS_THRESHOLD=0.92
TAXBOT_ANSWER_RELEVANCY_THRESHOLD=0.85
TAXBOT_CONTEXT_PRECISION_THRESHOLD=0.85
TAXBOT_CONTEXT_RECALL_THRESHOLD=0.85

# --- Operational ---
TAXBOT_LOG_LEVEL=INFO
TAXBOT_LOG_JSON=true
